# ProxyPanel Auto Generated Config
# Domain: {{.Domain}}
# Target: {{.TargetURL}}

{{if .SSLEnabled}}
server {
    listen 80;
    server_name {{.Domain}};
    
    # ACME Challenge (Let's Encrypt / ZeroSSL HTTP-01 validation)
    location /.well-known/acme-challenge/ {
        root /opt/proxypanel/ssl/acme;
    }
    
    # Redirect HTTP to HTTPS
    location / {
        return 301 https://$server_name$request_uri;
    }
}

server {
    {{if gt .Port 0}}
    listen {{.Port}} ssl http2;
    {{else}}
    listen 443 ssl http2;
    {{end}}
    server_name {{.Domain}};
    
    # SSL Configuration
    ssl_certificate {{.SSLCert}};
    ssl_certificate_key {{.SSLKey}};
    
    # SSL Security Settings
    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_ciphers ECDHE-ECDSA-AES128-GCM-SHA256:ECDHE-RSA-AES128-GCM-SHA256:ECDHE-ECDSA-AES256-GCM-SHA384:ECDHE-RSA-AES256-GCM-SHA384;
    ssl_prefer_server_ciphers off;
    ssl_session_cache shared:SSL:10m;
    ssl_session_timeout 1d;
    
    # Resolver for dynamic upstream DNS (force IPv4 via OS-level disable_ipv6)
    resolver 8.8.8.8 114.114.114.114 valid=300s;
    
{{else}}
server {
    {{if gt .Port 0}}
    listen {{.Port}};
    {{else}}
    listen 80;
    {{end}}
    server_name {{.Domain}};
    
    # ACME Challenge (Let's Encrypt / ZeroSSL HTTP-01 validation)
    location /.well-known/acme-challenge/ {
        root /opt/proxypanel/ssl/acme;
    }
    
    # Resolver for dynamic upstream DNS (force IPv4 via OS-level disable_ipv6)
    resolver 8.8.8.8 114.114.114.114 valid=300s;
    
{{end}}
    
{{if .Whitelist}}
    # IP Whitelist
    # Allowed IPs: {{len .Whitelist}}
    
    set $allow_ip false;
    
    {{range $i, $ip := .Whitelist}}
    if ($remote_addr = "{{$ip}}") {
        set $allow_ip true;
    }
    {{end}}
    
    if ($allow_ip = false) {
        return 403;
    }
    
{{end}}
    
    location / {
        {{if .IsTargetHTTPS}}
        # HTTPS upstream: use variable form + resolver to force IPv4
        set $upstream_url "{{.TargetURL}}";
        proxy_pass $upstream_url;
        
        # HTTPS Upstream SSL Settings
        proxy_ssl_server_name on;
        proxy_ssl_verify off;
        proxy_ssl_protocols TLSv1.2 TLSv1.3;
        {{else}}
        proxy_pass {{.TargetURL}};
        {{end}}
        
        # Proxy Headers
        proxy_set_header Host {{.TargetHost}};
        proxy_set_header X-Real-IP {{if .FakeIP}}{{.FakeIP}}{{else}}$remote_addr{{end}};
        proxy_set_header X-Forwarded-For {{if .FakeIP}}{{.FakeIP}}{{else}}$proxy_add_x_forwarded_for{{end}};
        proxy_set_header X-Forwarded-Proto $scheme;
        
        {{if .Token}}
        # API Token Authentication
        proxy_set_header X-API-KEY "{{.Token}}";
        {{end}}
        
        # Proxy Timeouts
        proxy_connect_timeout 60s;
        proxy_send_timeout 60s;
        proxy_read_timeout 60s;
        
        # Proxy Buffering
        proxy_buffering on;
        proxy_buffer_size 4k;
        proxy_buffers 8 4k;
        
        # Security Headers
        add_header X-Frame-Options "SAMEORIGIN" always;
        add_header X-Content-Type-Options "nosniff" always;
        add_header X-XSS-Protection "1; mode=block" always;
        
        # Hide Backend Info
        proxy_hide_header X-Powered-By;
        proxy_hide_header Server;
        
        # Logging
        access_log /var/log/nginx/proxy_{{.Domain}}_{{if gt .Port 0}}{{.Port}}{{else}}80{{end}}_access.log;
        error_log /var/log/nginx/proxy_{{.Domain}}_{{if gt .Port 0}}{{.Port}}{{else}}80{{end}}_error.log;
    }
}
